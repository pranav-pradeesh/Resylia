{
  "name": "@resylia/slack-bot",
  "version": "0.1.0",
  "private": true,
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn app.ts",
    "build": "tsc --skipLibCheck",
    "start": "node dist/app.js",
